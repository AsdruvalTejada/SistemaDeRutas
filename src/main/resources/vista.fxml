<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="700.0" spacing="10.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
   </padding>

   <Label text="🚍 Sistema Inteligente de Rutas" textFill="#2c3e50">
      <font>
         <Font name="System Bold" size="24.0" />
      </font>
   </Label>

   <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

      <Tab text="📍 Gestión de Paradas">
         <VBox spacing="15.0">
            <padding>
               <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>

            <Label text="Datos de la Nueva Parada:">
               <font><Font name="System Bold" size="14.0" /></font>
            </Label>

            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <Label prefWidth="70.0" text="ID:" />
               <TextField fx:id="txtParadaId" promptText="Ej: P4" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <Label prefWidth="70.0" text="Nombre:" />
               <TextField fx:id="txtParadaNombre" prefWidth="250.0" promptText="Ej: Parque Central" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <Label prefWidth="70.0" text="Coord X:" />
               <TextField fx:id="txtParadaX" promptText="Ej: 15.5" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <Label prefWidth="70.0" text="Coord Y:" />
               <TextField fx:id="txtParadaY" promptText="Ej: 20.0" />
            </HBox>

            <HBox spacing="15.0">
               <Button fx:id="btnAgregarParada" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="➕ Agregar Parada" />
               <Button fx:id="btnEliminarParada" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-weight: bold;" text="🗑️ Eliminar Parada" />
            </HBox>
         </VBox>
      </Tab>

      <Tab text="🛣️ Gestión de Rutas">
         <VBox spacing="15.0">
            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
            <Label text="(Aquí pondremos los campos de las rutas más adelante)">
               <font><Font name="System Italic" size="14.0" /></font>
            </Label>
         </VBox>
      </Tab>

      <Tab text="🧠 Calculadora de Viajes">
         <VBox spacing="15.0">
            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
            <Label text="(Aquí conectaremos a Dijkstra, BFS y Bellman-Ford)">
               <font><Font name="System Italic" size="14.0" /></font>
            </Label>
         </VBox>
      </Tab>

   </TabPane>

   <Label text="Consola del Sistema:">
      <font><Font name="System Bold" size="12.0" /></font>
   </Label>
   <TextArea fx:id="txtConsola" editable="false" prefHeight="150.0" promptText="Iniciando sistema..." style="-fx-control-inner-background: #1e1e1e; -fx-text-fill: #00ff00; -fx-font-family: 'Consolas';" />
</VBox>
