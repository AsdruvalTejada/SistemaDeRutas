<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<SplitPane dividerPositions="0.35" prefHeight="720.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <items>
      <VBox minWidth="400.0" spacing="20.0" style="-fx-background-color: #f1f2f6; -fx-border-color: #d1d8e0; -fx-border-width: 0 1 0 0;">
         <padding><Insets bottom="25.0" left="25.0" right="25.0" top="25.0" /></padding>
         <children>
            <Label text="Sistema de Rutas" textFill="#1e3799">
               <font><Font name="System Bold" size="28.0" /></font>
            </Label>

            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
               <tabs>
                  <Tab text="Paradas">
                     <VBox spacing="15.0" style="-fx-padding: 20 0 0 0;">
                        <Label text="Guía rápida:" textFill="#57606f" style="-fx-font-weight: bold;" />
                        <Label text="1. Haz clic en el mapa para situar un punto." textFill="#747d8c" wrapText="true" />
                        <TextField fx:id="txtParadaNombre" promptText="Nombre del Lugar" style="-fx-background-radius: 5; -fx-padding: 8;" />
                        <Button fx:id="btnAgregarParada" maxWidth="Infinity" style="-fx-background-color: #4a69bd; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Guardar en Mapa" />
                     </VBox>
                  </Tab>
                  <Tab text="Conexiones">
                     <VBox spacing="12.0" style="-fx-padding: 20 0 0 0;">
                        <ComboBox fx:id="comboRutaOrigen" maxWidth="Infinity" promptText="Seleccione Origen" style="-fx-background-radius: 5;" />
                        <ComboBox fx:id="comboRutaDestino" maxWidth="Infinity" promptText="Seleccione Destino" style="-fx-background-radius: 5;" />
                        <HBox spacing="10.0">
                           <TextField fx:id="txtRutaTiempo" promptText="Minutos" HBox.hgrow="ALWAYS" style="-fx-padding: 8;" />
                           <TextField fx:id="txtRutaCosto" promptText="Costo $" HBox.hgrow="ALWAYS" style="-fx-padding: 8;" />
                        </HBox>
                        <Button fx:id="btnAgregarRuta" maxWidth="Infinity" style="-fx-background-color: #4a69bd; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Conectar Paradas" />
                        <Button fx:id="btnEliminarRuta" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #eb4d4b; -fx-border-color: #eb4d4b; -fx-border-radius: 5; -fx-cursor: hand;" text="Eliminar Conexión" />
                     </VBox>
                  </Tab>
                  <Tab text="Viaje">
                     <VBox spacing="12.0" style="-fx-padding: 20 0 0 0;">
                        <ComboBox fx:id="comboCalcOrigen" maxWidth="Infinity" promptText="Punto de Partida" style="-fx-background-radius: 5;" />
                        <ComboBox fx:id="comboCalcDestino" maxWidth="Infinity" promptText="Punto de Llegada" style="-fx-background-radius: 5;" />
                        <ComboBox fx:id="comboCriterio" maxWidth="Infinity" promptText="Criterio" style="-fx-background-radius: 5;" />
                        <Button fx:id="btnCalcular" maxWidth="Infinity" style="-fx-background-color: #4a69bd; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Calcular Mejor Ruta" />
                     </VBox>
                  </Tab>
               </tabs>
            </TabPane>

            <VBox spacing="5.0">
               <Label text="Estado:" textFill="#7f8c8d" />
               <Label fx:id="lblEstado" text="Listo" style="-fx-background-color: #dfe4ea; -fx-padding: 10; -fx-background-radius: 5; -fx-font-weight: bold;" maxWidth="Infinity" wrapText="true" />
            </VBox>
         </children>
      </VBox>

      <AnchorPane fx:id="anchorMapa" style="-fx-background-color: #2f3542;">
         <children>
            <Pane fx:id="graphPane" style="-fx-cursor: crosshair;"
                  AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" />
            <VBox alignment="TOP_RIGHT" pickOnBounds="false" style="-fx-padding: 20;" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <Label text="MAPA INTERACTIVO" textFill="#2f3542" style="-fx-font-size: 35; -fx-font-weight: bold; -fx-opacity: 0.3;" />
            </VBox>
         </children>
      </AnchorPane>
   </items>
</SplitPane>